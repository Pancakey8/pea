dim res(2)
dim rep = 1

label:
dim x = rep + 1

class Foo
  dim arr(x)
  
  public static sub make()
    dim f = new Foo
    for i = 1 to x
      let (f.arr)(i) = i
    end for
    return f
  end sub

  public sub toString()
    return "Foo" & this.arr
  end sub
end class

let res(rep) = Foo.make()

if rep = 1 then
  let rep = 2
  goto label
end if

println(res)

